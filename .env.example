# =============================================================================
# Adaptive SOC CoPilot — Environment Variables Template
# Copy this file to .env and fill in all values before running the project.
# NEVER commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_DB=soc_copilot
POSTGRES_USER=soc_admin
POSTGRES_PASSWORD=change_this_strong_password_in_production

# Full DATABASE_URL used by SQLAlchemy (use internal Docker host "db" in Docker Compose)
DATABASE_URL=postgresql://soc_admin:change_this_strong_password_in_production@localhost:5432/soc_copilot

# -----------------------------------------------------------------------------
# Security & JWT
# -----------------------------------------------------------------------------
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-this-to-a-very-long-random-secret-key-minimum-64-characters-recommended

# JWT algorithm — do not change unless you know what you are doing
ALGORITHM=HS256

# Access token lifetime in minutes (default: 15 min)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 7 days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Adaptive SOC CoPilot
APP_VERSION=1.0.0

# development | production | testing
ENVIRONMENT=development

# Set to false in production
DEBUG=true

# -----------------------------------------------------------------------------
# CORS (comma-separated list of allowed frontend origins)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Email Notifications (Gmail SMTP)
# Use an App Password — NOT your Gmail account password.
# How to create: Google Account → Security → 2-Step Verification → App Passwords
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-char-gmail-app-password
SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_FROM_NAME=SOC CoPilot

# Enable/disable email sending (useful to set false in dev/test)
EMAIL_ENABLED=false

# -----------------------------------------------------------------------------
# Machine Learning
# -----------------------------------------------------------------------------
# Directory where trained model files (.pkl) are stored
MODEL_STORAGE_PATH=./ml_models

# Contamination parameter for Isolation Forest (expected anomaly fraction)
ISOLATION_FOREST_CONTAMINATION=0.05

# Minimum number of labeled samples required before retraining triggers
RETRAIN_MIN_SAMPLES=50
